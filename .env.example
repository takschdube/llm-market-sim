# LLM Market Simulation - Environment Variables
#
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# For multi-model experiments, you need API keys for all providers you want to test.

# DeepSeek API (cost-efficient flagship)
# Get your key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-key-here

# Anthropic API (Claude Sonnet 4.5)
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-key-here

# OpenAI API (GPT-5.2)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# Google API (Gemini 3 Pro)
# Get your key from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-key-here
